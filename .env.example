# PVMark Environment Configuration
# Copy this file to .env and fill in your values

# Your testnet private key (DO NOT COMMIT REAL KEY)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC endpoint
WESTEND_RPC=https://eth-rpc-testnet.polkadot.io

# Network name
NETWORK=polkadotHubTestnet

# Deployed contract addresses (will be set after deployment)
PVMARK_SOLIDITY_ADDRESS=0x0000000000000000000000000000000000000000
PVMARK_RUST_ADDRESS=0x0000000000000000000000000000000000000000
